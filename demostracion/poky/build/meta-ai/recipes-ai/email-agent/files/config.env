# ================================================================
#  /etc/email-agent/config.env
# ================================================================

GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

CHECK_INTERVAL=60

# qwen2.5:3b es significativamente mejor que gemma2:2b para seguir
# instrucciones estrictas y responder basándose en un documento de contexto.
# En Pi 5 tarda entre 6 y 9 minutos por respuesta, pero las respuestas
# son correctas y no alucina productos ni precios.
OLLAMA_MODEL=qwen2.5:3b

OLLAMA_URL=http://localhost:11434

# ----------------------------------------------------------------
# PERSONALIDAD DEL AGENTE
# ----------------------------------------------------------------
PERSONALITY=Responde de forma profesional y amigable. Firma como "Equipo de Ventas - TecnoPartes S.A."
