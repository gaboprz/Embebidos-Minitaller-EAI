#!/bin/sh
# ================================================================
#  /root/.xinitrc — Sesión X11
#  Define qué se ejecuta cuando startx arranca el servidor X.
# ================================================================

# Lanzar Matchbox WM en background.
# Gestiona las ventanas en modo embebido sin decoraciones pesadas.
matchbox-wm &

# Lanzar xterm como proceso principal (foreground).
# Cuando xterm se cierra, X11 termina y la sesión vuelve a tty1,
# donde getty volverá a hacer autologin automáticamente.
exec xterm -fa Monospace -fs 12 -title "RPi5 Terminal"
